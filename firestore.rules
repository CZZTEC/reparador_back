rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // =========================
    // DEMANDAS
    // =========================
    match /demands/{demandId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && 
        request.resource.data.clientId == request.auth.uid;
      // ⭐ ATUALIZAÇÃO: Cliente pode atualizar tudo, qualquer um autenticado pode atualizar proposalCount/isClosed
      allow update: if isLoggedIn() && (
        resource.data.clientId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['proposalCount', 'isClosed', 'updatedAt']))
      );
      allow delete: if isLoggedIn() && 
        (resource.data.clientId == request.auth.uid || isAdmin());
    }

    // =========================
    // PROPOSTAS
    // =========================
    match /proposals/{proposalId} {
      allow read: if isLoggedIn();
      
      // ⭐ Profissional precisa de plano ativo para enviar proposta
      allow create: if isLoggedIn() && 
        request.resource.data.get('professionalId', null) == request.auth.uid &&
        isActiveProfessional();
      
      // ✅ CORRIGIDO: Obter clientId da demanda relacionada
      allow update: if isLoggedIn() && (
        // Profissional pode atualizar sua própria proposta
        resource.data.get('professionalId', null) == request.auth.uid ||
        // Cliente pode atualizar apenas status de resposta + contraproposta
        (request.auth.uid == get(/databases/$(database)/documents/demands/$(resource.data.get('demandId', ''))).data.clientId && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'status', 'clientResponseAt', 'rejectionReason',
           'hasCounterProposal', 'lastCounterProposalAt'
         ])
        ) ||
        // Admin pode atualizar tudo
        isAdmin()
      );
      
      allow delete: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid || 
        isAdmin()
      );
    }

    // =========================
    // ⭐ ENCERRAMENTOS DE DEMANDA (NOVO)
    // =========================
    match /demand_closures/{closureId} {
      // Qualquer um autenticado pode ler
      allow read: if isLoggedIn();
      
      // Só o cliente pode criar encerramento
      allow create: if isLoggedIn() && 
        request.resource.data.clientId == request.auth.uid;
      
      // Não permitir update/delete (registro permanente)
      allow update: if false;
      allow delete: if isAdmin();
    }

    // =========================
    // JOBS/TRABALHOS
    // =========================
    match /jobs/{jobId} {
      allow read: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isLoggedIn() && (
        request.resource.data.clientId == request.auth.uid ||
        request.resource.data.professionalId == request.auth.uid
      );
      
      allow update: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid ||
        resource.data.clientId == request.auth.uid
      );
      
      allow delete: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
    }

    // =========================
    // PROFISSIONAIS
    // =========================
    match /professionals/{professionalId} {
      allow read: if isLoggedIn();
      allow write: if isOwner(professionalId);
    }

    // =========================
    // USUÁRIOS
    // =========================
    match /users/{userId} {
      allow read: if isLoggedIn() && isOwner(userId);
      allow create: if isLoggedIn() && isOwner(userId);
      allow update: if isLoggedIn() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // =========================
    // EMPRESAS/LOJAS
    // =========================
    match /businesses/{businessId} {
      allow read: if isLoggedIn();
      allow write: if isOwner(businessId);
    }

    // =========================
    // CHATS
    // =========================
    match /chats/{chatId} {
      // Read: user must be a participant
      allow read: if isLoggedIn() &&
        request.auth.uid in resource.data.get('participants', []);

      // Create: user must include themselves in participants
      allow create: if isLoggedIn() &&
        request.auth.uid in request.resource.data.get('participants', []);

      // Update: user must already be a participant (typing, online, unread, etc.)
      allow update: if isLoggedIn() &&
        request.auth.uid in resource.data.get('participants', []);

      // Delete: participants or admin
      allow delete: if isLoggedIn() && (
        request.auth.uid in resource.data.get('participants', []) ||
        isAdmin()
      );
    }

    match /chats/{chatId}/messages/{messageId} {
      // Helper: fetch parent chat participants safely
      function chatParticipants() {
        return get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', []);
      }

      allow read: if isLoggedIn() &&
        request.auth.uid in chatParticipants();

      // Create: participant sending a normal message OR a system message
      allow create: if isLoggedIn() &&
        request.auth.uid in chatParticipants() &&
        (request.resource.data.senderId == request.auth.uid ||
         request.resource.data.senderId == 'system');

      // Update: sender edits own message OR any participant marks isRead/readAt
      allow update: if isLoggedIn() &&
        request.auth.uid in chatParticipants() &&
        (resource.data.senderId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['isRead', 'readAt']));

      allow delete: if isLoggedIn() &&
        resource.data.senderId == request.auth.uid;
    }

    // =========================
    // CONTRAPROPOSTAS
    // =========================
    match /counter_proposals/{counterProposalId} {
      allow read: if isLoggedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.professionalId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isLoggedIn() &&
        request.resource.data.clientId == request.auth.uid;

      // Professional responds (accepted/rejected) OR client updates their own
      allow update: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // =========================
    // AVALIAÇÕES (REVIEWS)
    // =========================
    match /reviews/{reviewId} {
      // Apenas usuários autenticados dentro do contexto podem ler
      allow read: if isLoggedIn() && (
        request.auth.uid == resource.data.clientId ||
        request.auth.uid == resource.data.professionalId ||
        isAdmin()
      );
      
      // Só o cliente pode criar avaliação
      allow create: if isLoggedIn() && 
        request.resource.data.clientId == request.auth.uid;
      
      // Só o cliente pode atualizar sua avaliação
      allow update: if isLoggedIn() && 
        (resource.data.clientId == request.auth.uid || isAdmin());
      
      // Avaliações são permanentes (só admin pode deletar)
      allow delete: if isAdmin();
    }

    // =========================
    // NOTIFICAÇÕES
    // =========================
    match /notifications/{userId} {
      // User can read their own notification container doc
      allow read, write: if isLoggedIn() && isOwner(userId);

      match /items/{itemId} {
        // User can read and update (mark as read) their own notifications
        allow read: if isLoggedIn() && isOwner(userId);
        allow update: if isLoggedIn() && isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        // Only Cloud Functions (Admin SDK) can create/delete
        allow create, delete: if false;
      }
    }

    // =========================
    // CONTATOS
    // =========================
    match /contatos/{contactId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if false;
    }

    // =========================
    // RELATÓRIOS/DENÚNCIAS
    // =========================
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isLoggedIn() && 
        request.resource.data.reportedBy == request.auth.uid;
      allow update, delete: if isModerator();
    }

    // =========================
    // CONFIGURAÇÕES DO APP
    // =========================
    match /appConfig/{document=**} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // =========================
    // CADASTROS
    // =========================
    match /cadastros/{docId} {
      allow read: if isLoggedIn();
      allow write: if false; // Só via Admin SDK
    }

    // =========================
    // RATE LIMITS
    // =========================
    match /rate_limits/{userId} {
      allow read, write: if isLoggedIn() && 
        request.auth.uid == userId;
    }

    // =========================
    // UPLOADS DE ARQUIVOS
    // =========================
    match /uploads/{userId}/{document=**} {
      allow read, write: if isLoggedIn() && 
        (request.auth.uid == userId || isAdmin());
    }

    // =========================
    // ANALYTICS (Apenas Admins)
    // =========================
    match /analytics/{document=**} {
      allow read, write: if isAdmin();
    }

    // =========================
    // LOGS DE SEGURANÇA (Apenas Admins)
    // =========================
    match /securityLogs/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // =========================
    // ADMIN ONLY DATA
    // =========================
    match /adminOnlyData/{document=**} {
      allow read, write: if false; // Só via Admin SDK
    }

    // =========================
    // BACKUPS (Apenas Admins)
    // =========================
    match /backups/{document=**} {
      allow read, write: if isAdmin();
    }

    // =========================
    // SERVICES DO PROFISSIONAL / OFERTAS
    // =========================
    match /professional_services/{serviceId} {
      allow read: if isLoggedIn();
      
      // ⭐ Profissional precisa de plano ativo para criar uma oferta
      allow create: if isLoggedIn() && 
        request.resource.data.professionalId == request.auth.uid &&
        isActiveProfessional();
      
      allow update: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid ||
        isAdmin()
      );
      
      allow delete: if isLoggedIn() && (
        resource.data.professionalId == request.auth.uid || 
        isAdmin()
      );
    }

    // =========================
    // REGRA PADRÃO: NEGAR TUDO
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================
    // ✅ FUNÇÕES DE SEGURANÇA
    // =========================
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isModerator() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'moderator';
    }

    // ⭐ Verifica se o profissional tem plano ativo
    function isActiveProfessional() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('subscription', {}).get('status', '') == 'active';
    }
  }
}